# FIXONEX website — environment scaffolding
# Copy to `.env.local` for local development. Never commit `.env.local`.

# -----------------------------------------------------------------------------
# Optional: public site URL (used if you add absolute OG URLs or sitemaps later)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=https://www.your-domain.com

# -----------------------------------------------------------------------------
# Optional: contact form API (implement Route Handler or Server Action that reads these)
# -----------------------------------------------------------------------------
# CONTACT_FORM_WEBHOOK_URL=
# RESEND_API_KEY=
# CONTACT_EMAIL_TO=info@fixonex.com

# -----------------------------------------------------------------------------
# Optional: analytics (only if you add a provider)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_ANALYTICS_ID=

# No secrets are required to run the marketing site locally. Forms currently use
# a mock client-side submit helper documented in README.md.
